  "tables": [
    {
      "name": "tbproduct",
      "columns": [
        {
          "name": "product_id",
          "type": "BIGINT UNSIGNED",
          "attributes": ["PRIMARY KEY", "AUTO_INCREMENT"]
        },
        {
          "name": "name",
          "type": "VARCHAR(255)",
          "attributes": ["NOT NULL"]
        },
        {
          "name": "description",
          "type": "TEXT",
          "attributes": ["NULL"]
        },
        {
          "name": "category",
          "type": "VARCHAR(100)",
          "attributes": ["NULL"]
        },
        {
          "name": "tag",
          "type": "VARCHAR(100)",
          "attributes": ["NULL"]
        },
        {
          "name": "product_type",
          "type": "VARCHAR(50)",
          "attributes": ["NULL"]
        },
        {
          "name": "price",
          "type": "DECIMAL(10,2)",
          "attributes": ["NOT NULL"]
        },
        {
          "name": "photo",
          "type": "VARCHAR(255)",
          "attributes": ["NULL"]
        },
        {
          "name": "status",
          "type": "ENUM('Available','Unavailable')",
          "default": "Available"
        },
        {
          "name": "created_at",
          "type": "TIMESTAMP",
          "attributes": ["NULL"]
        },
        {
          "name": "updated_at",
          "type": "TIMESTAMP",
          "attributes": ["NULL"]
        }
      ],
      "indexes": [
        "category (idx_product_category)",
        "status (idx_product_status)"
      ]
    },
    {
      "name": "tbproduct_gallery",
      "columns": [
        {
          "name": "product_gallery_id",
          "type": "BIGINT UNSIGNED",
          "attributes": ["PRIMARY KEY", "AUTO_INCREMENT"]
        },
        {
          "name": "product_id",
          "type": "BIGINT UNSIGNED",
          "attributes": ["NOT NULL", "FOREIGN KEY"]
        },
        {
          "name": "image_url",
          "type": "VARCHAR(500)",
          "attributes": ["NOT NULL"]
        },
        {
          "name": "created_at",
          "type": "TIMESTAMP",
          "attributes": ["NULL"]
        },
        {
          "name": "updated_at",
          "type": "TIMESTAMP",
          "attributes": ["NULL"]
        }
      ],
      "indexes": ["product_id"],
      "foreignKeys": ["product_id -> tbproduct.product_id ON DELETE CASCADE"]
    }
  ],

  "validations": {
    "create": {
      "nombre": ["required", "string", "max:255", "unique:tbproduct,name"],
      "descripcion": ["nullable", "string"],
      "categoria": ["nullable", "string", "max:100"],
      "etiqueta": ["nullable", "string", "max:100"],
      "tipo_producto": ["nullable", "string", "max:50"],
      "precio": ["required", "numeric", "min:0"],
      "foto": ["nullable", "string", "max:255"],
      "estado": ["required", "in:Disponible,No disponible"]
    },
    "gallery": {
      "image_url": ["required", "string", "max:500"]
    }
  },

